# ============================================================================
# TrainChat — Environment Variable Reference
# ============================================================================
#
# SAFETY RULES — READ BEFORE USING THIS FILE
#
#   1. NEVER commit real secrets to the repository.
#      This file contains ONLY placeholder values. Real values belong
#      in the Replit Secrets panel (Tools → Secrets).
#
#   2. Some variables are injected automatically by Replit.
#      PORT, DATABASE_URL, REPLIT_DOMAINS, REPLIT_DEV_DOMAIN, REPL_ID,
#      REPL_IDENTITY, REPLIT_CONNECTORS_HOSTNAME, and WEB_REPL_RENEWAL
#      are never set manually — Replit provides them at runtime.
#      They are listed here for documentation only.
#
#   3. Non-secret shared values are committed in .replit [userenv.shared].
#      STRIPE_PRICE_* IDs, EMAIL_FROM, and EMAIL_SUPPORT_TO live there.
#      Do not duplicate them here or in Replit Secrets.
#
#   4. For local development, copy this file to .env (which is gitignored)
#      and fill in development-only values. Never use production keys locally.
#
#   5. Required vs Optional: see STATUS column below.
#      "REQUIRED" = server will not start or core feature will fail.
#      "OPTIONAL" = feature degrades gracefully if missing.
#      "REPLIT-INJECTED" = never set manually; included for documentation.
#
# ============================================================================


# ============================================================================
# SECTION 1 — Core Replit / Runtime
# ============================================================================
# These are injected by Replit automatically. Do NOT set them in Secrets.
# Listed here so engineers and AI agents know they exist and where they come from.

# [REPLIT-INJECTED] Port the server must listen on.
# Source: Replit runtime. Throws at startup if missing.
# Used in: artifacts/api-server/src/index.ts
PORT=3000

# [REPLIT-INJECTED] Comma-separated list of public deployment domains.
# Source: Replit runtime. Used to construct the Stripe webhook URL and
# billing portal return URL.
# Used in: src/index.ts, src/routes/stripe.ts, src/lib/session.ts
REPLIT_DOMAINS=your-repl-name.repl.co

# [REPLIT-INJECTED] Development-environment domain (no HTTPS prefix).
# Source: Replit runtime. Used as fallback for APP_URL in password reset emails.
# Used in: src/routes/auth.ts
REPLIT_DEV_DOMAIN=your-repl-name.repl.co

# [REPLIT-INJECTED] Unique identifier for the Replit Repl.
# Source: Replit runtime. Used by Vite configs to detect Replit environment.
# Used in: artifacts/trainchat/vite.config.ts, artifacts/mockup-sandbox/vite.config.ts
REPL_ID=your-repl-id

# [REPLIT-INJECTED] Replit identity token for internal Replit API calls.
# Source: Replit runtime. Used by the Stripe product setup script to authenticate
# with Replit Connectors.
# Used in: scripts/src/setup-trainchat-stripe-products.ts, scripts/src/seed-products.ts
REPL_IDENTITY=

# [REPLIT-INJECTED] Hostname for Replit Connectors SDK.
# Source: Replit runtime. Used by the Stripe product setup script.
# Used in: scripts/src/setup-trainchat-stripe-products.ts, scripts/src/seed-products.ts
REPLIT_CONNECTORS_HOSTNAME=

# [REPLIT-INJECTED] Deployment renewal token.
# Source: Replit runtime. Fallback identity token when REPL_IDENTITY is absent.
# Used in: scripts/src/setup-trainchat-stripe-products.ts, scripts/src/seed-products.ts
WEB_REPL_RENEWAL=

# [OPTIONAL] Node environment. Set to "production" in the Replit production environment.
# Affects: cookie security (Secure + SameSite=none when "production"), debug route guard.
# Used in: src/lib/session.ts, src/routes/debug.ts
NODE_ENV=development


# ============================================================================
# SECTION 2 — Database
# ============================================================================

# [REPLIT-INJECTED] PostgreSQL connection string.
# Source: Replit database provisioning. lib/db/src/index.ts throws at import
# time if this is missing.
# Used in: lib/db/src/index.ts, src/index.ts (Stripe schema migration)
DATABASE_URL=postgresql://user:password@localhost:5432/trainchat


# ============================================================================
# SECTION 3 — OpenAI / AI Models
# ============================================================================

# [REQUIRED for AI] OpenAI API key. Used for all program generation, editing,
# routing, memory extraction, and intent interpretation.
# Models used: gpt-4.1 (core, generation, edits), gpt-4.1-mini (routing, memory).
# If missing, AI calls fail with 401. Server starts but chat returns errors.
# Used in: src/lib/ai.ts (line 3383)
OPENAI_API_KEY=sk-your-openai-api-key-here

# [OPTIONAL] Replit AI integration key. Used as fallback if OPENAI_API_KEY is
# not set. Replit may inject this via the AI integration panel.
# If OPENAI_API_KEY is set, it takes precedence over this value.
# Used in: src/lib/ai.ts (line 3383)
AI_INTEGRATIONS_OPENAI_API_KEY=

# [OPTIONAL] Custom base URL for OpenAI-compatible API endpoints.
# Only used when OPENAI_API_KEY is absent and AI_INTEGRATIONS_OPENAI_API_KEY
# is used instead. Defaults to https://api.openai.com/v1.
# Use this to point at Azure OpenAI, a proxy, or a local model server.
# Used in: src/lib/ai.ts (line 3384)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1


# ============================================================================
# SECTION 4 — Stripe / Billing
# ============================================================================

# [REQUIRED] Stripe secret key. Server exits at startup if missing.
# Use sk_test_... for development, sk_live_... for production.
# Used in: src/lib/billingUtils.ts (validateBillingConfig), src/lib/stripeClient.ts
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# [REQUIRED] Stripe webhook signing secret (whsec_...).
# Server exits at startup if missing. Auto-configured by stripe-replit-sync
# on deployment — this value is set after first startup when the webhook is
# registered. If rotating, restart the server after updating.
# Used in: src/lib/billingUtils.ts, src/lib/webhookHandlers.ts
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# [OPTIONAL] Stripe publishable key. Sent to the frontend for Stripe Elements.
# Not required for server-side billing to function.
# Used in: src/routes/billing.ts (returned to frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# --- Stripe Price IDs --------------------------------------------------
# NOTE: The values below are already set in .replit [userenv.shared] for the
# primary environment. Do not add them to Replit Secrets — that would create
# duplicates. They are shown here for documentation and local dev use only.
#
# These are OPTIONAL fallbacks for webhook plan detection. The primary
# mechanism uses Stripe lookup_keys (e.g. trainchat_pro_monthly).
# Server warns if missing but does not fail.
# Run `pnpm --filter @workspace/scripts run stripe:setup-products` to generate.
# Used in: src/lib/billingUtils.ts

# Current active plan
STRIPE_PRICE_TRAINCHAT_MONTHLY=price_1Tn35DGOcsf8J09luBjtpksA

# Legacy plan price IDs — retained for existing subscriber webhook detection
STRIPE_PRICE_STARTER_MONTHLY=price_1TU6FyGOcsf8J09lot01Ih0x
STRIPE_PRICE_STARTER_YEARLY=price_1TU6FzGOcsf8J09ljmm1v6VT
STRIPE_PRICE_PRO_MONTHLY=price_1TU6G0GOcsf8J09lZDwHKJw7
STRIPE_PRICE_PRO_YEARLY=price_1TU6G0GOcsf8J09lSi6pmaMK
STRIPE_PRICE_ELITE_MONTHLY=price_1TU6G1GOcsf8J09lww9pih1g
STRIPE_PRICE_ELITE_YEARLY=price_1TU6G2GOcsf8J09l1QtpEvW2

# --- Stripe Checkout / Portal URLs ------------------------------------
# [OPTIONAL] All three have fallbacks derived from REPLIT_DOMAINS or
# request.host, so they work without being set on Replit.
# Set these to enforce specific redirect destinations in production.

# Success URL for Stripe Checkout. Supports {CHECKOUT_SESSION_ID} token.
# Default: https://<host>/?checkout=success&session_id={CHECKOUT_SESSION_ID}
# Used in: src/routes/stripe.ts
STRIPE_CHECKOUT_SUCCESS_URL=https://www.trainchat.ai/?checkout=success&session_id={CHECKOUT_SESSION_ID}

# Cancel URL for Stripe Checkout.
# Default: https://www.trainchat.ai
# Used in: src/routes/stripe.ts
STRIPE_CHECKOUT_CANCEL_URL=https://www.trainchat.ai

# Return URL after Stripe billing portal session.
# Default: https://<REPLIT_DOMAINS[0]>/billing (or CLIENT_URL/billing)
# Used in: src/routes/stripe.ts
STRIPE_BILLING_PORTAL_RETURN_URL=https://www.trainchat.ai/billing


# ============================================================================
# SECTION 5 — SendGrid / Email
# ============================================================================
# Email is NON-FATAL. If SENDGRID_API_KEY is missing, email is skipped and
# a warning is logged. DB records (support, bug reports) are always saved.

# [OPTIONAL] SendGrid API key (starts with SG.).
# If absent, all email is skipped silently.
# Requires a verified sender address in the SendGrid dashboard.
# Used in: src/lib/email.ts
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# [OPTIONAL] Sender address for transactional email.
# Must be verified in SendGrid. Defaults to Bryan.jones@efficiencystrengthtraining.com
# (set in .replit [userenv.shared]).
# NOTE: Also set in .replit [userenv.shared] — only override here for local dev.
# Used in: src/lib/email.ts (EMAIL_FROM), src/lib/webhookHandlers.ts (SENDGRID_FROM_EMAIL)
EMAIL_FROM=Bryan.jones@efficiencystrengthtraining.com

# [OPTIONAL] Alias used in Stripe webhook handler for sending billing-related emails.
# Falls back to noreply@trainchat.app if not set.
# IMPORTANT: this is a second env var name for the same concept as EMAIL_FROM.
# They serve the same purpose in different modules. Recommend keeping them in sync.
# Used in: src/lib/webhookHandlers.ts (line 531)
SENDGRID_FROM_EMAIL=noreply@trainchat.app

# [OPTIONAL] Internal address for support/bug/feature request notification emails.
# Defaults to Bryan.jones@trainchat.ai (set in .replit [userenv.shared]).
# NOTE: Also set in .replit [userenv.shared] — only override here for local dev.
# Used in: src/lib/email.ts
EMAIL_SUPPORT_TO=Bryan.jones@trainchat.ai


# ============================================================================
# SECTION 6 — Auth / Session / Security
# ============================================================================

# [REQUIRED] Express session signing secret.
# Must be a long, random, unique string. Server throws at startup if missing.
# CHANGING THIS IN PRODUCTION LOGS OUT ALL USERS — rotate with care.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Used in: src/lib/session.ts
SESSION_SECRET=your-very-long-random-session-secret-here


# ============================================================================
# SECTION 7 — Admin / Security
# ============================================================================

# [OPTIONAL] Bearer token for /api/admin/* routes.
# Set in .replit [userenv.production] for production. Listed here for awareness.
# Format: Authorization: Bearer <ADMIN_SECRET>
# Used in: src/routes/admin.ts, src/routes/whitepapers-admin.ts (secondary check)
ADMIN_SECRET=your-admin-secret-here

# [OPTIONAL] Comma-separated list of email addresses with admin access.
# When set, /api/admin/* and /api/whitepapers-admin/* check both ADMIN_SECRET
# (header-based) AND this list (session user email). Either grants access.
# Example: bryan@trainchat.ai,engineer@trainchat.ai
# Used in: src/routes/admin.ts, src/routes/whitepapers-admin.ts
ADMIN_EMAILS=


# ============================================================================
# SECTION 8 — Frontend / Client URLs
# ============================================================================

# [OPTIONAL] Public URL of the TrainChat client app.
# Used in retention email CTAs and Stripe billing portal return URL fallback.
# Default: https://trainchat.ai (hardcoded in email templates)
# Used in: src/lib/email.ts, src/routes/stripe.ts
CLIENT_URL=https://www.trainchat.ai

# [OPTIONAL] Public URL of the API server / app.
# Used to construct password reset email links.
# Fallback chain: APP_URL → REPLIT_DEV_DOMAIN → https://www.trainchat.ai
# Used in: src/routes/auth.ts (password reset flow)
APP_URL=https://www.trainchat.ai

# [OPTIONAL — SCRIPTS ONLY] Explicit webhook URL override for the Stripe product
# setup script. If set, the script registers this URL as the Stripe webhook
# endpoint instead of deriving it from REPLIT_DOMAINS or CLIENT_URL.
# Only relevant when running `pnpm --filter @workspace/scripts run stripe:setup-products`.
# Not used by the API server at runtime.
# Used in: scripts/src/setup-trainchat-stripe-products.ts
WEBHOOK_URL=

# [REQUIRED by Vite builds] Base path for frontend artifact builds.
# Replit injects this during build. Required by all vite.config.ts files
# (trainchat, mockup-sandbox, wp-* prototypes). Throws at build time if missing.
# Used in: artifacts/trainchat/vite.config.ts and all other artifact vite configs
BASE_PATH=/


# ============================================================================
# SECTION 9 — Logging
# ============================================================================

# [OPTIONAL] Pino log level. One of: trace, debug, info, warn, error, fatal.
# Default: info
# Used in: src/lib/logger.ts
LOG_LEVEL=info

# [OPTIONAL] Enable verbose language-layer audit logging.
# Set to "true" to log AI response language audits. High volume — use for debugging only.
# Default: false (feature disabled)
# Used in: src/lib/ai.ts
LOG_LANGUAGE_AUDIT=false

# [OPTIONAL] Enable verbose response policy audit logging.
# Set to "true" to log policy enforcement decisions. High volume — use for debugging only.
# Default: false (feature disabled)
# Used in: src/lib/ai.ts
LOG_RESPONSE_POLICY_AUDIT=false


# ============================================================================
# SECTION 10 — Research Discovery (Optional Integration)
# ============================================================================

# [OPTIONAL] Enable automated research discovery from PubMed and Semantic Scholar
# on server startup. Default: false. Leave off unless actively maintaining the
# research corpus. Requires coaching knowledge seeders to have run first.
# Used in: src/research/research-discovery-service.ts
RESEARCH_DISCOVERY_ENABLED=false

# [OPTIONAL] PubMed API key for higher rate limits.
# Without it, the unauthenticated PubMed rate limit applies (3 requests/second).
# Used in: src/research/research-discovery-service.ts
PUBMED_API_KEY=

# [OPTIONAL] Email address for PubMed API politeness header (NCBI requires this
# for API access). Default: research@trainchat.app
# Used in: src/research/research-discovery-service.ts
PUBMED_EMAIL=research@trainchat.app

# [OPTIONAL] Semantic Scholar API key for higher rate limits.
# Without it, anonymous rate limits apply (~100 requests/5 min).
# Used in: src/research/research-discovery-service.ts
SEMANTIC_SCHOLAR_API_KEY=


# ============================================================================
# SECTION 11 — Meta Conversions API (Optional Integration)
# ============================================================================

# [OPTIONAL] Meta Conversions API (CAPI) token.
# If absent, CAPI events are skipped silently.
# Used in: src/routes/meta-capi.ts
META_CAPI_TOKEN=


# ============================================================================
# SECTION 12 — Billing Reconciliation Tuning (Optional)
# ============================================================================

# [OPTIONAL] How often the billing reconciliation cron runs, in milliseconds.
# Default: 86400000 (24 hours). Lower in dev to test reconciliation faster.
# Used in: src/lib/billingReconciliation.ts
BILLING_RECONCILIATION_INTERVAL_MS=86400000

# [OPTIONAL] How many days a subscription can be past_due before reconciliation
# flags it for sync. Default: 3
# Used in: src/lib/billingReconciliation.ts
BILLING_RECONCILIATION_THRESHOLD_DAYS=3


# ============================================================================
# SECTION 13 — Debug / Development Only
# ============================================================================
# ⚠️  NEVER set DEBUG_RESET_ENABLED=true in production.

# [OPTIONAL — NEVER IN PRODUCTION] Enable /api/debug/* routes.
# These routes allow resetting anonymous user state. The debug router checks
# NODE_ENV === "production" AND this var — if both conditions are met (production
# + explicitly opted in), debug routes are still blocked.
# Default: false (routes return 403 in production regardless)
# Used in: src/routes/debug.ts
DEBUG_RESET_ENABLED=false
