modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
STRIPE_PRICE_STARTER_MONTHLY = "price_1TIYT5GOcsf8J09lKmI1806Q"
STRIPE_PRICE_STARTER_YEARLY = "price_1TIYT5GOcsf8J09l14kpf3zn"
STRIPE_PRICE_PRO_MONTHLY = "price_1TIYT6GOcsf8J09liwTgBS2B"
STRIPE_PRICE_PRO_YEARLY = "price_1TIYT6GOcsf8J09lwEsSUGIB"
STRIPE_PRICE_ELITE_MONTHLY = "price_1TIYT7GOcsf8J09l1wnaZMge"
STRIPE_PRICE_ELITE_YEARLY = "price_1TIYT7GOcsf8J09lOHjWItMD"
